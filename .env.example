# Optional: Yahoo proxy backend URL (production or `npm run dev:api` + Vite together).
# When unset, the app uses same-origin `/yahoo` (Vite dev proxy or reverse proxy in prod).
# Example: http://127.0.0.1:8787 or https://api.yourdomain.com
# VITE_YAHOO_API_BASE=http://127.0.0.1:8787

# Server (server/yahoo-proxy.mjs) — not Vite; set when running `node server/yahoo-proxy.mjs`
# PORT=8787
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app
