{
  "name": "stonks",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/yahoo-proxy.mjs",
    "dev:full": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"vite\"",
